    "@safecast/api": "workspace:*",
    "@safecast/auth": "workspace:*",
    "@safecast/db": "workspace:*",
    "@safecast/env": "workspace:*",
    "@trpc/server": "catalog:",
    "ai": "^6.0.0",
    "better-auth": "catalog:",
