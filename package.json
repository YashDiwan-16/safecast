{
  "name": "safecast",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=server",
    "deploy:setup": "vercel link",
    "dev:vercel": "vercel dev -L",
    "env:preview": "tsx scripts/sync-vercel-env.ts preview",
    "env:production": "tsx scripts/sync-vercel-env.ts production",
    "deploy": "vercel deploy",
    "deploy:prod": "vercel deploy --prod",
    "deploy:check": "vercel deploy --dry"
  },
  "dependencies": {
    "@safecast/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@safecast/config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "nx": "^23.0.1",
    "tsx": "^4.22.5",
    "typescript": "catalog:",
    "vercel": "^54.18.6"
  },
  "packageManager": "pnpm@10.6.2"
}
